{
  "name": "main branch protection",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": 2023440,
      "actor_type": "User"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_approving_review_count": 1
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          { "context": "Node 22 on ubuntu-latest", "integration_id": 15368 },
          { "context": "Node 22 on macos-latest", "integration_id": 15368 },
          { "context": "Node 22 on windows-latest", "integration_id": 15368 },
          { "context": "Node 24 on ubuntu-latest", "integration_id": 15368 },
          { "context": "Node 24 on macos-latest", "integration_id": 15368 },
          { "context": "Node 24 on windows-latest", "integration_id": 15368 }
        ]
      }
    },
    {
      "type": "required_linear_history"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "deletion"
    }
  ]
}
