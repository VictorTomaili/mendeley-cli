# EditorConfig: https://editorconfig.org
# Top-most EditorConfig file; more specific files override this.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown documents may end sentences with two trailing spaces (line break).
[*.md]
trim_trailing_whitespace = false

# Makefiles require tab indentation.
[Makefile]
indent_style = tab

# Windows batch / PowerShell keep CRLF for maximum tool compatibility.
[*.{bat,cmd,ps1}]
end_of_line = crlf
